t "" 4 "Launch path B, Response D" { 4, 3 }
p "" 2 1 "" { "Response U" "Response D" } 0
t "" 5 "Launch path C, Response U" { 2, 1 }
t "" 6 "Launch path C, Response D" { 8, 7 }
