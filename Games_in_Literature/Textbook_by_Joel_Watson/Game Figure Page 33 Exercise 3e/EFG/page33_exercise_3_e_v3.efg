EFG 2 R "Software Launch" { "1" "2" }
""

p "" 1 1 "" { "Launch path A" "Launch path B" "Launch path C" } 0
p "" 2 1 "" { "Response U" "Response D" } 0
t "" 1 "Launch path A, Response U" { 2, 1 }
t "" 2 "Launch path A, Response D" { 1, 2 }
p "" 2 1 "" { "Response U" "Response D" } 0
